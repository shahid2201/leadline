APP_NAME=Lead Line API
APP_ENV=local
LOG_LEVEL=INFO
API_PREFIX=/v1

DATABASE_URL=postgresql+asyncpg://leadline:leadline@postgres:5432/leadline
REDIS_URL=redis://redis:6379/0

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=

SQS_AI_JOBS_QUEUE_URL=
SQS_ROUTING_JOBS_QUEUE_URL=
SQS_EMAIL_JOBS_QUEUE_URL=
SQS_SMS_JOBS_QUEUE_URL=
SQS_SEQUENCE_JOBS_QUEUE_URL=
SQS_INTEGRATION_JOBS_QUEUE_URL=

JWT_SECRET=change-me-in-real-environments
JWT_ALGORITHM=HS256
JWT_AUDIENCE=leadline-api
JWT_ISSUER=leadline

OPENAI_API_KEY=
OPENAI_MODEL_MINI=gpt-4o-mini
OPENAI_MODEL_FULL=gpt-4o
AI_PROMPT_VERSION=v1
AI_CACHE_TTL_SECONDS=3600

SES_FROM_EMAIL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=

HUBSPOT_API_BASE_URL=https://api.hubapi.com
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_WEBHOOK_SECRET=

GOOGLE_CALENDAR_API_BASE_URL=https://www.googleapis.com/calendar/v3
GOOGLE_CALENDAR_ACCESS_TOKEN=

SLACK_WEBHOOK_URL=
SLACK_SIGNING_SECRET=

SVIX_SERVER_URL=https://api.svix.com
SVIX_TOKEN=
SVIX_APP_ID=
SVIX_WEBHOOK_SECRET=

INTEGRATION_MAX_RETRIES=3

OTEL_ENABLED=true
OTEL_SERVICE_NAME=leadline-api
OTEL_EXPORTER_OTLP_ENDPOINT=

RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120

AUDIT_LOG_ENABLED=true
PII_MASKING_ENABLED=true
APP_DATA_ENCRYPTION_KEY=
ENFORCE_TENANT_HEADER_MATCH=true

AUTO_CREATE_TABLES=true
